{
  "name": "vertex-api-cloudflare-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:pages && npx wrangler pages dev dist",
    "build": "npm run build:pages",
    "build:pages": "npm run bundle && node scripts/prepare-pages.mjs",
    "deploy": "npm run build:pages",
    "deploy:worker": "npx wrangler deploy --config wrangler.worker.toml",
    "bundle": "esbuild src/index.js --bundle --format=esm --platform=browser --target=es2022 --outfile=dist/worker.js",
    "check": "node --check src/index.js && node --check src/openaiGeminiMapper.js && node --check src/anthropicGeminiMapper.js && node --check src/vertexClient.js"
  },
  "devDependencies": {
    "esbuild": "^0.27.0",
    "wrangler": "^4.0.0"
  }
}
